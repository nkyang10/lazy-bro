{
  "manifest_version": 3,
  "name": "Lazy Browser",
  "version": "1.0.0",
  "description": "Lazy Browser — AI-powered web assistant that analyzes pages and automates clicks",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
